# Copy this file to config.toml and fill in your details.
# config.toml is gitignored — your file paths will never be committed.
#
# Add one [[accounts]] entry per brokerage account. Each entry needs:
#   brokerage — which parser to use (schwab, robinhood, fidelity, merrill)
#   csv       — path to the exported transaction CSV
#               (relative to repo root, or absolute)
#
# Optional per-account keys:
#   symbols   — list of tickers to chart; omit to chart every symbol in the CSV

[[accounts]]
brokerage = "schwab"
csv       = "input/schwab.csv"
symbols = ["PFE", "SCHW", "GOOGL"]

# [[accounts]]
# brokerage = "robinhood"
# csv       = "input/robinhood_transactions.csv"

# [[accounts]]
# brokerage = "fidelity"
# csv       = "input/fidelity.csv"

# [[accounts]]
# brokerage = "merrill"
# csv       = "input/merrill.csv"

# Output directory for generated HTML files (default: cost-basis-charts/output/).
[output]
dir = "output"
